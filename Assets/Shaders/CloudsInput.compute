#pragma kernel CSMain

#include "Common.hlsl"
#include "Noise.hlsl"

float ResolutionInv;

RWTexture3D<float4> Output;

[numthreads(8, 8, 8)]
void CSMain(uint3 id : SV_DispatchThreadID)
{
    float3 uvw = TexelToUV(id, ResolutionInv);
    
    Output[id] = float4(id.x & id.y & id.z, PerlinWorley(uvw, 5, 0.0, 1, 0.5, 5), AlligatorDecima(uvw), 1.0);
}
